# ---------------------------------------------------------------------------
# Hook7 (WhatsApp infrastructure)
# ---------------------------------------------------------------------------
# Chave global da plataforma S7 — não compartilhar com clientes.
# Necessária para criar e gerenciar instâncias WhatsApp via Hook7.
HOOK7_GLOBAL_APIKEY=

# Prefixo dos nomes de instância no Hook7 (rastreabilidade entre produtos).
HOOK7_INSTANCE_PREFIX=lead
